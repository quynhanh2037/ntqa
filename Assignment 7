import random

cars = []

for i in range(1, 11):
    reg_number = f"ABC-{i}"
    max_speed = random.randint(150, 200)
    car = Car(reg_number, max_speed)
    cars.append(car)

race_finished = False

while not race_finished:
    for car in cars:
        change = random.randint(-10, 15)
        car.accelerate(change)
        car.drive(1)

        if car.travelled_distance >= 10000:
            race_finished = True

print(f"{'Reg Number':<10} {'Max Speed':<10} {'Speed':<10} {'Distance':<10}")

for car in cars:
    print(f"{car.registration_number:<10} {car.max_speed:<10} {car.current_speed:<10} {car.travelled_distance:.2f}")
