#6 Middle Character
def middle_char(given_text):
    length = len(given_text)
    mid = length // 2
    if length % 2 == 0:
        return given_text[mid - 1: mid + 1]
    else:
        return given_text[mid]
    
#7 Acronym
def acronym(given_phrase):
    words = given_phrase.split()
    result = ""
    for word in words:
        result += word[0].upper()
    return result
