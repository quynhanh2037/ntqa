#Prime Numbers
number = int(input("Enter an integer: "))
if number <= 1:
    print("Not prime")
else:
    prime = True
    for i in range(2, number):
        if number % i == 0:
            prime = False
    if prime:
        print("Prime number")
    else:
        print("Not prime")

#Greatest Numbers
numbers = []
while True:
    numbers_list = input("Enter a number (press Enter as empty to stop): ")
    if numbers_list == "":
        break
    num = float(numbers_list)
    numbers.append(num)
numbers.sort(reverse=True)
top_five = numbers[:5]
print("Five greatest numbers:", top_five)

